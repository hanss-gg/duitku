{
  "name": "duitku-bot",
  "version": "1.0.0",
  "description": "Telegram bot untuk Duitku — Hybrid Parser (Regex + Gemini)",
  "main": "app.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "start:bot": "node index.js",
    "start:server": "node server.js",
    "dev": "nodemon index.js",
    "dev:server": "nodemon server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "setup:token": "node scripts/get-token.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.24.1",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-session": "^1.18.0",
    "googleapis": "^140.0.0",
    "telegraf": "^4.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
