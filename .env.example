# ============================================================
#  DUITKU — Environment Variables
#  Salin file ini menjadi .env dan isi dengan nilai asli kamu
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # Dari @BotFather di Telegram
TELEGRAM_ALLOWED_CHAT_ID=  # Chat ID kamu (cek via @userinfobot)

# ── Google API ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=          # Dari Google Cloud Console
GOOGLE_CLIENT_SECRET=      # Dari Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback
GOOGLE_SHEETS_ID=          # ID spreadsheet Google Sheets kamu
GOOGLE_TOKEN=              # JSON token (jalankan: npm run setup:token)

# ── Google Gemini AI (Natural parsing & OCR) ─────────────────
GEMINI_API_KEY=            # Dari Google AI Studio (aistudio.google.com)

# ── App ──────────────────────────────────────────────────────
ALLOWED_EMAIL=             # Email Google kamu (whitelist login dashboard)
SESSION_SECRET=            # String acak panjang, contoh: openssl rand -hex 32
NODE_ENV=development

# ── URL ──────────────────────────────────────────────────────
PORT=3001                          # Port backend/server
DASHBOARD_URL=http://localhost:3006 # URL dashboard (ganti saat production)
WEBHOOK_URL=https://your-app-domain.com # URL domain kamu untuk webhook bot (production)
VITE_API_URL=http://localhost:3001  # (untuk dashboard, di file dashboard/.env.example)
